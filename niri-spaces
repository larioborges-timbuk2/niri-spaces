#!/usr/bin/env bash
# Populates workspaces exactly as requested

# Workspace 1
niri msg action focus-workspace 1
niri msg action spawn ghostty
sleep 0.5
niri msg action spawn brave-origin
sleep 0.5

# Workspaces 2 to 5
for n in {2..5}; do
    niri msg action focus-workspace "$n"
    
    # 1. terminal
    niri msg action spawn ghostty
    sleep 0.5
    
    # 2. vscodium
    niri msg action spawn codium "$HOME/timbuk2/t2-mono-$n/t2-mono-$n.code-workspace"
    sleep 0.5
    
    # 3. terminal
    niri msg action spawn ghostty
    sleep 0.5
    
    # 4. chrome
    niri msg action spawn google-chrome
    sleep 0.5
    
    # 5. brave
    niri msg action spawn brave-origin
    sleep 0.5
    
    # 6. gram editor
    if command -v gram &> /dev/null; then
        niri msg action spawn gram "$HOME/timbuk2/t2-mono-$n/"
    else
        niri msg action spawn flatpak run app.liten.Gram "$HOME/timbuk2/t2-mono-$n/"
    fi
    sleep 0.5
done

# Return to workspace 1
niri msg action focus-workspace 1
