#!/usr/bin/env bash
# Populates workspaces exactly as requested

# Workspace 1
niri msg action focus-workspace 1
niri msg action spawn -- ghostty
sleep 0.5
niri msg action spawn -- google-chrome
sleep 0.5
niri msg action spawn -- brave-origin
sleep 0.5

# Workspaces 2 to 5
for n in {1..4}; do
    niri msg action focus-workspace-down
    
    # 1. vscodium
    niri msg action spawn -- flatpak run com.vscodium.codium "$HOME/timbuk2/t2-mono-$n/t2-mono-$n.code-workspace"
    sleep 0.6
    niri msg action set-column-width 30%
    
    # 2. terminal
    niri msg action spawn -- ghostty --working-directory "$HOME/timbuk2/t2-mono-$n/"
    sleep 0.6
    niri msg action set-column-width 30%
    
    # 3. broot (20% width)
    niri msg action spawn -- ghostty -e broot "$HOME/timbuk2/t2-mono-$n/"
    sleep 0.6
    niri msg action set-column-width 20%
    

    # 6. gram editor
    niri msg action spawn -- flatpak run app.liten.Gram "$HOME/timbuk2/t2-mono-$n/"
    sleep 0.6
    niri msg action set-column-width 30%
done

# Return to workspace 1
niri msg action focus-workspace 1
